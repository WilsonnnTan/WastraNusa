// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// --------------- ENUM -----------------

enum Gender {
  male
  female
}

enum ArticleStatus {
  draft
  published
  archived
}

enum ProductStatus {
  active
  inactive
  out_of_stock
}

enum VariantType {
  size
  color
}

enum OrderStatus {
  pending
  confirmed
  processing
  shipped
  delivered
  cancelled
}

enum PaymentStatus {
  unpaid
  paid
  failed
  refunded
}

enum PaymentTransactionStatus {
  pending
  success
  failed
  expired
}

// --------------- Table -----------------

model User {
  id            String  @id
  name          String
  email         String
  emailVerified Boolean @default(false)
  image         String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  sessions  Session[]
  accounts  Account[]

  articles          Article[]         @relation("ArticleCreatedBy")
  customerAddresses CustomerAddress[]
  orders            Order[]
  userArticleLikes  UserArticleLike[]
  cart Cart?

  role       String?
  banned     Boolean?  @default(false)
  banReason  String?
  banExpires DateTime?

  phoneNumber String?
  gender      String?
  birthDate   DateTime?

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  impersonatedBy String?

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Article {
  id          String  @id
  title       String
  slug        String  @unique
  description String?

  province    String
  island      String
  region      String
  ethnicGroup String?

  clothingType String
  gender       Gender

  wikipediaPageId   String    @unique
  wikipediaUrl      String
  wikimediaImageUrl String?
  wikimediaVideoUrl String?
  wikipediaLastSync DateTime?

  summary String?

  sections ArticleSection[]

  status    ArticleStatus @default(published)
  createdBy String
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  // Relations
  creator    User               @relation("ArticleCreatedBy", fields: [createdBy], references: [id])
  products   Product[]
  engagement ArticleEngagement?
  userLikes  UserArticleLike[]

  @@index([province])
  @@index([ethnicGroup])
  @@index([clothingType])
  @@index([status, province])
  @@map("article")
}

model Product {
  id          String  @id
  articleId   String
  name        String
  slug        String  @unique
  description String?

  price          Decimal
  compareAtPrice Decimal?

  stock Int    @default(0)
  sku   String @unique

  weight Int

  province     String
  clothingType String
  gender       Gender

  status ProductStatus @default(active)
  sold   Int           @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  article  Article          @relation(fields: [articleId], references: [id], onDelete: Restrict)
  variants ProductVariant[]
  orders   Order[]
  cartItems CartItem[]

  @@index([province])
  @@index([clothingType])
  @@index([gender])
  @@map("product")
}

model ProductVariant {
  id        String @id
  productId String

  name  String
  type  VariantType
  price Decimal?
  stock Int         @default(0)
  sku   String      @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  orders  Order[]
  cartItems CartItem[]

  @@index([type])
  @@map("product_variant")
}

model CustomerAddress {
  id String @id

  userId String

  label         String
  recipientName String
  phone         String

  province    String
  city        String
  district    String
  subdistrict String?
  postalCode  String
  fullAddress String

  notes     String?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@index([userId])
  @@map("customer_address")
}

model Order {
  id String @id

  orderNumber String @unique
  userId      String

  productId    String
  variantId    String?
  productName  String
  variantName  String?
  quantity     Int
  productPrice Decimal

  shippingAddressId String

  courier           String
  courierService    String
  estimatedDelivery String?
  trackingNumber    String?

  subtotal     Decimal
  shippingCost Decimal
  totalAmount  Decimal

  orderStatus   OrderStatus   @default(pending)
  paymentStatus PaymentStatus @default(unpaid)
  paymentMethod String?

  paidAt      DateTime?
  shippedAt   DateTime?
  deliveredAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  customerNotes String?

  // Relations
  user                User                 @relation(fields: [userId], references: [id], onDelete: Restrict)
  product             Product              @relation(fields: [productId], references: [id], onDelete: Restrict)
  variant             ProductVariant?      @relation(fields: [variantId], references: [id], onDelete: SetNull)
  shippingAddress     CustomerAddress      @relation(fields: [shippingAddressId], references: [id], onDelete: Restrict)
  paymentTransactions PaymentTransaction[]

  @@index([userId])
  @@index([productId])
  @@index([orderStatus])
  @@index([paymentStatus])
  @@map("order")
}

model PaymentTransaction {
  id         String                   @id
  orderId    String
  externalId String                   @unique
  amount     Decimal
  status     PaymentTransactionStatus

  paymentUrl String?
  vaNumber   String?
  qrCode     String?

  expiredAt DateTime?
  paidAt    DateTime?
  createdAt DateTime

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([externalId])
  @@index([status])
  @@map("payment_transaction")
}

model ArticleEngagement {
  id        String   @id
  articleId String   @unique
  viewCount Int      @default(0)
  likeCount Int      @default(0)
  updatedAt DateTime @updatedAt

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@map("article_engagement")
}

model UserArticleLike {
  id        String   @id
  articleId String
  userId    String
  createdAt DateTime @default(now())

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([articleId])
  @@index([userId])
  @@map("user_article_like")
}

model Cart {
  id        String     @id
  userId    String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]

  @@map("cart")
}

model CartItem {
  id        String   @id
  cartId    String
  productId String
  variantId String?
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cart      Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@unique([cartId, productId, variantId])
  @@index([cartId])
  @@index([productId])
  @@map("cart_item")
}

model ArticleSection {
  id           String  @id @default(uuid())
  articleId    String
  title        String
  content      String
  imageLabel   String?
  imageCaption String?
  order        Int     @default(0)

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId])
  @@map("article_section")
}